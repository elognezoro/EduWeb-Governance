# ── Base de données PostgreSQL (Neon) ─────────────────────────────
# URL « pooled » (PgBouncer) — utilisée par l'application au runtime (Vercel).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# URL « direct » (sans -pooler) — utilisée par Prisma pour `db push` / migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# ── Session (optionnel) ───────────────────────────────────────────
# Nom du cookie de session (défaut : eduweb_session).
SESSION_COOKIE_NAME="eduweb_session"
